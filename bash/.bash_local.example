# ~/.bash_local - Machine-specific configuration
# Copy this file to ~/.bash_local and customize for each machine
# This file is NOT tracked in version control
#
# Usage: cp ~/.bash_local.example ~/.bash_local

# =============================================================================
# Work-Specific Paths
# =============================================================================

# Example: Add workspace tools to PATH
# export PATH=/workspaces/myproject/.tools/bin:$PATH

# Example: Unset Go variables if using workspace-specific Go
# unset GOPATH
# unset GOROOT

# =============================================================================
# Work-Specific Environment Variables
# =============================================================================

# Example: Set review base branch
# export REVIEW_BASE=master

# Example: Work proxy settings
# export HTTP_PROXY=http://proxy.example.com:8080
# export HTTPS_PROXY=http://proxy.example.com:8080
# export NO_PROXY=localhost,127.0.0.1,.example.com

# =============================================================================
# Machine-Specific Aliases
# =============================================================================

# Example: SSH shortcuts
# alias dev1='ssh dev1.example.com'
# alias dev2='ssh dev2.example.com'

# =============================================================================
# Machine-Specific Tool Configurations
# =============================================================================

# Example: Set different Python version for this machine
# export PYENV_VERSION=3.11.0

# Example: Use different Java version
# export JAVA_HOME=/usr/lib/jvm/java-17-openjdk

# =============================================================================
# Secrets and Tokens (NEVER commit these!)
# =============================================================================

# Example: API tokens
# export GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# export NPM_TOKEN=npm_xxxxxxxxxxxx
